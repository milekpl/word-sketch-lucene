{
  "version": "1.0-test",
  "description": "Test grammar configuration",
  "relations": [
    {
      "id": "noun_modifiers",
      "name": "Modifiers (adjectives)",
      "description": "Adjectives modifying nouns",
      "pattern": "[xpos=\"JJ.*\"] [xpos=\"NN.*\"]",
      "head_position": 2,
      "collocate_position": 1,
      "relation_type": "SURFACE"
    },
    {
      "id": "noun_adj_predicates",
      "name": "Adjectives (predicative)",
      "description": "Adjective predicates with copula",
      "pattern": "[xpos=\"NN.*\"] [lemma=\"be|appear|seem\"] [xpos=\"JJ.*\"]",
      "head_position": 1,
      "collocate_position": 3,
      "relation_type": "SURFACE"
    },
    {
      "id": "noun_verbs",
      "name": "Nearby verbs",
      "description": "Verbs near the noun in a wider window",
      "pattern": "[xpos=\"NN.*\"] [xpos=\"VB.*\"]",
      "head_position": 1,
      "collocate_position": 2,
      "relation_type": "SURFACE"
    },
    {
      "id": "subject_of",
      "name": "Subject verbs",
      "description": "Verbs for which the noun is the subject",
      "pattern": "[xpos=\"NN.*\"] [xpos=\"VB.*\"]",
      "head_position": 1,
      "collocate_position": 2,
      "relation_type": "SURFACE"
    },
    {
      "id": "verb_subjects",
      "name": "Subject nouns",
      "description": "Nouns occurring as subjects of the verb",
      "pattern": "[xpos=\"NN.*\"] []{0,3} [xpos=\"VB.*\"]",
      "head_position": 3,
      "collocate_position": 1,
      "relation_type": "SURFACE"
    },
    {
      "id": "verb_nouns",
      "name": "Nearby nouns",
      "description": "Nouns near the verb in a wider window",
      "pattern": "[xpos=\"VB.*\"] [xpos=\"NN.*\"]",
      "head_position": 1,
      "collocate_position": 2,
      "relation_type": "SURFACE"
    },
    {
      "id": "object_of",
      "name": "Object nouns",
      "description": "Nouns occurring as direct objects of the verb",
      "pattern": "[xpos=\"VB.*\"] [xpos=\"NN.*\"]",
      "head_position": 1,
      "collocate_position": 2,
      "relation_type": "SURFACE"
    }
  ]
}
